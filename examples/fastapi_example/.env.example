# 支付宝配置
ALIPAY_APP_ID=2016********
# 应用私钥，使用 \n 作为换行符
ALIPAY_APP_SECRET_CERT=-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----
# 应用公钥证书路径
ALIPAY_APP_PUBLIC_CERT_PATH=/path/to/appCertPublicKey.crt
# 支付宝公钥证书路径
ALIPAY_PUBLIC_CERT_PATH=/path/to/alipayCertPublicKey.crt
# 支付宝根证书路径
ALIPAY_ROOT_CERT_PATH=/path/to/alipayRootCert.crt
# 支付结果通知地址
ALIPAY_NOTIFY_URL=http://localhost:8000/notify/alipay
# 支付完成跳转地址
ALIPAY_RETURN_URL=http://localhost:8000/return/alipay

# 微信支付配置
# 商户号
WECHAT_MCH_ID=1600314069
# 商户API密钥
WECHAT_MCH_SECRET_KEY=e7368d422cfea4b70e91165e522c8fhr
# 商户私钥，使用 \n 作为换行符
WECHAT_MCH_SECRET_CERT=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----
# 商户证书路径
WECHAT_MCH_PUBLIC_CERT_PATH=/path/to/cert.pem
# 公众号APPID
WECHAT_MP_APP_ID=wx55955316af4ef13
# 小程序APPID
WECHAT_MINI_APP_ID=wx55955316af4ef14
# APP APPID
WECHAT_APP_ID=wx55955316af4ef15
# 支付结果通知地址
WECHAT_NOTIFY_URL=http://localhost:8000/notify/wechat
# 商户证书序列号
WECHAT_SERIAL_NUMBER=12345678
# 微信支付公钥ID
WECHAT_PUBLIC_CERT_KEY=123456789012345
# 微信支付公钥证书路径
WECHAT_PUBLIC_CERT_PATH=/path/to/public_cert.pem

# 银联支付配置
# 商户号
UNIPAY_MER_ID=123456789012345
# 商户私钥路径
UNIPAY_PRIVATE_KEY_PATH=/path/to/private_key.pem
# 商户公钥证书路径
UNIPAY_PUBLIC_CERT_PATH=/path/to/public_cert.pem
# 银联公钥证书路径
UNIPAY_PUBLIC_CERT_PATH=/path/to/unipay_cert.pem
# 支付结果通知地址
UNIPAY_NOTIFY_URL=http://localhost:8000/notify/unipay
# 支付完成跳转地址
UNIPAY_FRONT_URL=http://localhost:8000/return/unipay

# 抖音支付配置
# 应用ID
DOUYIN_APP_ID=800000000001
# 应用密钥
DOUYIN_APP_SECRET=1234567890abcdef1234567890abcdef
# 支付令牌
DOUYIN_TOKEN=douyintoken12345
# 签名盐值
DOUYIN_SALT=douyinsalt12345
# 支付结果通知地址
DOUYIN_NOTIFY_URL=http://localhost:8000/notify/douyin